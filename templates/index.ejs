<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EcoAvatar - Riciclo Intelligente</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #7459fe; --secondary: #41d9a5; --dark: #2c3e50; --light: #f8f9fa; }
    body { font-family: 'Poppins', sans-serif; background: linear-gradient(135deg, #f5f7fa 0%, #e4edf5 100%); min-height: 100vh; padding-bottom: 50px; }

    /* Stili esistenti per gli stati della connessione, ICE e segnalazione */
    .peerConnectionState-new { color: cornflowerblue; }
    .peerConnectionState-connecting { color: orange; }
    .peerConnectionState-connected { color: green; }
    .peerConnectionState-disconnected,
    .peerConnectionState-closed,
    .peerConnectionState-failed { color: red; }

    .iceConnectionState-new { color: cornflowerblue; }
    .iceConnectionState-checking { color: orange; }
    .iceConnectionState-connected,
    .iceConnectionState-completed { color: green; }
    .peerConnectionState-disconnected,
    .peerConnectionState-closed,
    .peerConnectionState-failed { color: red; }

    .iceGatheringState-new { color: cornflowerblue; }
    .iceGatheringState-gathering { color: orange; }
    .iceGatheringState-complete { color: black; }

    .signalingState-stable { color: green; }
    .signalingState-have-local-offer,
    .signalingState-have-remote-offer,
    .signalingState-have-local-pranswer,
    .signalingState-have-remote-pranswer { color: cornflowerblue; }
    .signalingState-closed { color: red; }

    .streamingState-streaming { color: green; }
    .streamingState-empty { color: grey; }

    .streamEvent-started { color: green; }
    .streamEvent-done { color: orange; }
    .streamEvent-ready { color: green; }
    .streamEvent-error { color: red; }
    .streamEvent-dont-care { color: gray; }

    /* Nuovi stili per la pagina */
    body * {
      font-family: 'Mulish', sans-serif;
      text-align: center;
    }

    #content {
      width: 820px;
      position: relative;
      margin: 0 auto;
    }

    #buttons {
      clear: both;
      padding: 0 0 0 0;
      text-align: center;
    }

    button {
      padding: 10px 20px;
      border-radius: 5px;
      border: none;
      font-size: 16px;
      margin: 0 5px;
      background-color: #7459fe;
      color: #fff;
    }

    button:hover {
      background-color: #9480ff;
      cursor: pointer;
      transition: all 0.2s ease-out;
    }

    #status {
      clear: both;
      padding: 20px 0 0 0;
      text-align: left;
      display: inline-block;
      zoom: 1;
      line-height: 140%;
      font-size: 15px;
    }

    #status div {
      padding-bottom: 10px;
    }

    #video-wrapper {
      background: url("/assets/images/bg.png");
      height: 500px;
      background-position: top;
    }

    #video-wrapper div {
      position: relative;
      height: 100%;
      width: 400px;
      margin: 0 auto;
    }

    #videoBot {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      /*border:1px solid;*/
      border-radius: 50%;
      background-color: #fff;

      object-fit: cover;
      background-size: cover;
      background-repeat: no-repeat;
      background-position: center;
      background-image: url("/assets/images/alex_v2_idle_image.png");
    }

    /* Container for camera and button */
    .camera-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin: 40px auto;
    }

    /* Square video container - NO border-radius */
    .cameraGrid {
      width: 320px;
      height: 240px;
      background-color: #000;
      overflow: hidden;
      border: 2px solid #ccc;
      position: relative;
    }

    /* Result image after snapshot */
    .cameraResult {
      margin-top: 20px;
      max-width: 320px;
      text-align: center;
    }

    .cameraResult img {
      width: 100%;
      height: auto;
      border: 2px solid #ccc;
      box-sizing: border-box;
      display: block;
      margin: 0 auto;
    }

    /* Button style */
    .snapshot-button {
      margin-top: 15px;
      padding: 10px 20px;
      font-size: 16px;
      background-color: #7459fe;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }

    .snapshot-button:hover {
      background-color: #9480ff;
    }

    /* Stili per la modale */
    .modal-video-container {
      position: relative;
      width: 100%;
      padding-top: 56.25%; /* 16:9 aspect ratio */
    }

    #modalAvatarVideo {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border-radius: 10px;
      display: none;
    }

    .spinner-container {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      display: none;
    }

    /* Fine nuovi stili */
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="#">EcoAvatar</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="#hero">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="#steps">Come Funziona</a></li>
          <li class="nav-item"><a class="nav-link" href="#camera-section">Fotocamera</a></li>
          <li class="nav-item"><a class="nav-link" href="#bins">Raccolta</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="hero" class="py-5">
    <div class="container text-center">
      <h1 class="display-4">EcoAvatar</h1>
      <p class="lead">La tua guida interattiva per il riciclo intelligente</p>
      <a href="#steps" class="btn btn-primary">Scopri di più</a>
    </div>
  </section>

  <!-- Steps Section -->
  <section id="steps" class="py-5 bg-light">
    <div class="container">
      <div class="row">
        <div class="col-md-4">
          <i class="fas fa-camera fa-3x mb-3" style="color: var(--primary);"></i>
          <h3>1. Scatta la foto</h3>
          <p>Cattura un’immagine del materiale da riciclare.</p>
        </div>
        <div class="col-md-4">
          <i class="fas fa-robot fa-3x mb-3" style="color: var(--primary);"></i>
          <h3>2. Analisi Intelligente</h3>
          <p>Grazie all’IA, riconosciamo il tipo di materiale.</p>
        </div>
        <div class="col-md-4">
          <i class="fas fa-recycle fa-3x mb-3" style="color: var(--primary);"></i>
          <h3>3. Ricicla</h3>
          <p>Ti guidiamo passo passo su dove smaltirlo e come farlo nel modo corretto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Camera Section (IMPORTANTE: deve avere #my_camera e #my_result) -->
  <section id="camera-section" class="py-5">
    <div class="container">
      <h2 class="mb-4">Scatta una Foto del Materiale</h2>
      <div class="camera-container">
        <!-- Contenitore Video Webcam -->
        <div id="my_camera" class="cameraGrid"></div>

        <!-- Bottone per scattare lo snapshot -->
        <button class="snapshot-button" onclick="take_snapshot()">Scatta Foto</button>

        <!-- Contenitore per mostrare il risultato dello snapshot -->
        <div id="my_result" class="cameraResult"></div>

        <!-- Bottone per inviare l’immagine al server -->
        <button class="snapshot-button mt-3" onclick="submitQuestion()">Invia per Analisi</button>
      </div>
    </div>
  </section>

  <!-- Avatar Response Modal -->
  <div class="modal fade" id="avatarModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">La tua guida al riciclo: Sara</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="modal-video-container">
            <div class="spinner-container" id="modalSpinner">
              <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            </div>
            <video id="modalAvatarVideo" playsinline></video>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bins Section -->
  <section id="bins" class="py-5 bg-light">
    <div class="container">
      <h2 class="mb-4">Dove Buttarlo</h2>
      <div class="row">
        <div class="col-md-4 text-center">
          <i class="fas fa-recycle fa-2x mb-2" style="color: var(--secondary);"></i>
          <h5>Carta</h5>
          <p>Raccolta nella plastica blu.</p>
        </div>
        <div class="col-md-4 text-center">
          <i class="fas fa-flask fa-2x mb-2" style="color: var(--secondary);"></i>
          <h5>Vetro</h5>
          <p>Raccolta nella campana verde.</p>
        </div>
        <div class="col-md-4 text-center">
          <i class="fas fa-plastic-bottle fa-2x mb-2" style="color: var(--secondary);"></i>
          <h5>Plastica</h5>
          <p>Raccolta nella plastica gialla.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-4 bg-dark text-white text-center">
    <div class="container">
      <p class="mb-0">&copy; 2025 EcoAvatar. Tutti i diritti riservati.</p>
    </div>
  </footer>

  <!-- Bootstrap & JavaScript -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/webcamjs/1.0.25/webcam.min.js"></script>
  <script>
    // Inizializza Webcam
    Webcam.set({
      width: 320,
      height: 240,
      image_format: 'jpeg',
      jpeg_quality: 90
    });
    // Ora il div #my_camera esiste, puoi agganciare la webcam
    Webcam.attach('#my_camera');

    // Scatta foto
    function take_snapshot() {
      Webcam.snap(function(data_uri) {
        document.getElementById('my_result').innerHTML = '<img src="' + data_uri + '" class="img-fluid" />';
      });
    }

    // Ridimensiona immagine per invio
    function resizeImage(imgElement, maxWidth) {
      return new Promise((resolve) => {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        const originalWidth = imgElement.naturalWidth;
        const originalHeight = imgElement.naturalHeight;
        const ratio = maxWidth / originalWidth;
        const newWidth = maxWidth;
        const newHeight = originalHeight * ratio;
        canvas.width = newWidth;
        canvas.height = newHeight;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(imgElement, 0, 0, newWidth, newHeight);
        resolve(canvas.toDataURL('image/jpeg', 0.8));
      });
    }

    // Mostra modale, invia immagine, ricevi risposta, mostra video avatar
    async function submitQuestion() {
      const imageElement = document.querySelector("#my_result img");
      if (!imageElement) {
        alert("Per favore scatta una foto prima.");
        return;
      }
      // Mostra modale con spinner
      const modal = new bootstrap.Modal(document.getElementById('avatarModal'));
      modal.show();
      document.getElementById('modalSpinner').style.display = 'flex';
      const video = document.getElementById('modalAvatarVideo');
      video.style.display = 'none';
      video.pause();
      video.removeAttribute('src');
      video.load();

      try {
        // Aspetta che l'immagine sia caricata
        if (!imageElement.complete) {
          await new Promise((resolve) => { imageElement.onload = resolve; });
        }
        // Riduci immagine
        const resizedData = await resizeImage(imageElement, 800);
        // Invia a backend
        const response = await fetch("/ask", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ imageData: resizedData })
        });
        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(`Server error: ${errorData.error || response.status}`);
        }
        const data = await response.json();
        if (data.answer) {
          // Chiedi a D-ID di generare il video
          await speakWithDID(data.answer, modal, video);
        } else {
          alert("Nessuna risposta ricevuta.");
          modal.hide();
          resetModal();
        }
      } catch (error) {
        console.error("Error:", error);
        alert("Errore: " + error.message);
        modal.hide();
        resetModal();
      }
    }

    // Chiamata a D-ID e gestione video nella modale
    async function speakWithDID(message, modal, video) {
      try {
        // Chiedi al backend di generare il video D-ID
        const response = await fetch('/generate-did-video', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: message })
        });
        if (!response.ok) throw new Error('Errore nella generazione del video');
        const { talkId } = await response.json();
        // Polling per stato video
        const videoUrl = await checkTalkStatus(talkId);
        // Mostra video nella modale
        document.getElementById('modalSpinner').style.display = 'none';
        video.style.display = 'block';
        video.src = videoUrl;
        video.volume = 0.7;
        video.play();
        video.onended = function() {
          setTimeout(() => {
            modal.hide();
            resetModal();
          }, 2000);
        };
      } catch (error) {
        alert("Errore nell'animazione dell'avatar: " + error.message);
        document.getElementById('modalSpinner').style.display = 'none';
        resetModal();
      }
    }

    // Polling stato video D-ID
    async function checkTalkStatus(talkId, retries = 20, interval = 1500) {
      for (let i = 0; i < retries; i++) {
        const response = await fetch(`/talk-status/${talkId}`);
        const data = await response.json();
        if (data.status === 'done' && data.result_url) {
          return data.result_url;
        } else if (data.status === 'error') {
          throw new Error('Errore nella generazione del video D-ID');
        }
        await new Promise(resolve => setTimeout(resolve, interval));
      }
      throw new Error('Timeout nella generazione del video');
    }

    // Reset modale
    function resetModal() {
      document.getElementById('modalSpinner').style.display = 'flex';
      const video = document.getElementById('modalAvatarVideo');
      video.style.display = 'none';
      video.pause();
      video.removeAttribute('src');
      video.load();
    }

    document.addEventListener('DOMContentLoaded', function() {
      console.log("EcoAvatar is ready!");
    });
  </script>
</body>
</html>
